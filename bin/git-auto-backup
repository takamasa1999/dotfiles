#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="${1:-$(pwd)}"
cd "$REPO_DIR" 2>/dev/null || {
	echo "Error: directory not found: $REPO_DIR" >&2
	exit 1
}
git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
	echo "Error: not a git repository: $REPO_DIR" >&2
	exit 1
}

# Stage any working tree changes
git add -A

# Commit if there are staged changes
if ! git diff --cached --quiet; then
	COMMIT_MESSAGE="$(date '+%Y%m%d-%H%M%S')"
	git commit -m "$COMMIT_MESSAGE"
	echo "Committed: $COMMIT_MESSAGE"
fi

# Push if local branch is ahead of remote (or has no upstream yet)
CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD)"
if ! git rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
	git push -u origin "$CURRENT_BRANCH"
	echo "Pushed (set upstream): $CURRENT_BRANCH"
elif [[ -n "$(git log '@{u}..HEAD' --oneline 2>/dev/null)" ]]; then
	git push
	echo "Pushed: $CURRENT_BRANCH"
else
	echo "Nothing to push."
fi
